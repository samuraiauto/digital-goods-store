PORT=3000
LISTEN_HOST=0.0.0.0

# Email (SMTP) — нужно для заявок и теста /api/admin/test-email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Куда приходят новые заявки с сайта (ваш рабочий email)
ORDER_NOTIFY_EMAIL=

# Отправлять ли клиенту письмо «заявка принята» (true по умолчанию: любое значение кроме false)
ORDER_SEND_CUSTOMER_CONFIRM=true

# Тест/админ эндпоинты
# Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=

# B2B поставщик (каталог; можно не трогать, если каталог временно не нужен)
SUPPLIER_BASE_URL=https://api.giftapi.ru/v1/partner
SUPPLIER_API_KEY=
SUPPLIER_SECRET=

SUPPLIER_CATEGORY_ID=37
SUPPLIER_TYPE=
SUPPLIER_INCLUDE_SKUS=true
SUPPLIER_PER_PAGE=100
SUPPLIER_DETAIL_CONCURRENCY=6

PUBLIC_ORIGIN=
