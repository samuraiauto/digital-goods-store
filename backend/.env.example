PORT=3000

# Публичный URL возврата после оплаты (страница на вашем сайте)
PUBLIC_RETURN_URL=http://localhost:3000/success.html

# YooKassa (СБП включается в личном кабинете YooKassa)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# (опционально) секрет вебхуков — зависит от настройки YooKassa
YOOKASSA_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# B2B поставщик
SUPPLIER_BASE_URL=
SUPPLIER_API_KEY=

# (опционально) путь к каталогу товаров у поставщика
# пример: /products или /api/v1/products
SUPPLIER_CATALOG_PATH=/products

# (опционально) CORS origin для /api (например ваш домен)
PUBLIC_ORIGIN=

