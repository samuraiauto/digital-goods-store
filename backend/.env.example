PORT=3000
LISTEN_HOST=0.0.0.0

# Публичный URL возврата после оплаты (страница на вашем сайте)
PUBLIC_RETURN_URL=http://localhost:3000/success.html

# YooKassa (СБП включается в личном кабинете YooKassa)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# (опционально) секрет вебхуков — зависит от настройки YooKassa
YOOKASSA_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# B2B поставщик
SUPPLIER_BASE_URL=https://api.giftapi.ru/v1/partner
SUPPLIER_API_KEY=
SUPPLIER_SECRET=

# Фильтры каталога (опционально)
SUPPLIER_CATEGORY_ID=37
SUPPLIER_TYPE=
SUPPLIER_INCLUDE_SKUS=true
SUPPLIER_PER_PAGE=100
SUPPLIER_DETAIL_CONCURRENCY=6

# (опционально) CORS origin для /api (например ваш домен)
PUBLIC_ORIGIN=

# Тест/админ эндпоинты (не включайте без надобности).
# Любой запрос к /api/admin/* требует заголовок:
# Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=

